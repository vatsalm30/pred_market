# Key ID shown in Kalshi dashboard after uploading your RSA public key
KALSHI_API_KEY_ID=your-key-id-here

# RSA private key (PEM) — use \n for newlines when setting in Fly.io secrets
KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Your deployed Vercel URL for the market list
MARKET_DATA_URL=https://your-app.vercel.app/data/matched_markets.json

PORT=8080
