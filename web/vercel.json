{
  "headers": [
    {
      "source": "/data/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=60"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/telegram/cron",
      "schedule": "*/10 * * * *"
    }
  ]
}
