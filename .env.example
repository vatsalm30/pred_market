# Kalshi credentials — use one of the two methods below
KALSHI_EMAIL=your_email@example.com
KALSHI_PASSWORD=your_password

# OR use an API key directly (takes priority over email/password if set)
KALSHI_API_KEY=

# Arbitrage settings
MIN_PROFIT_PCT=1.0          # minimum net profit % to display (1.0 = 1%)
SCAN_INTERVAL_SEC=30        # seconds between full scans
MATCH_THRESHOLD=0.65        # fuzzy similarity threshold for market pairing (0–1)
MAX_POLY_MARKETS=500        # cap on Polymarket markets fetched per scan
